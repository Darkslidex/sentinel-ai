# --- Entorno Virtual ---
venv/
.env
Include/
Lib/
Scripts/
pyvenv.cfg

# --- Python & Cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Modelos Pesados ---
