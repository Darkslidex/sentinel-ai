# y YOLO los descarga automáticamente si faltan.
*.pt

# --- Datos y Evidencias ---
# Es mejor no subir tus fotos personales a un repositorio público.
# GitHub no es para almacenar imágenes pesadas.
data/captures/*.jpg

# --- IDEs y Sistema ---
.vscode/
.idea/
.DS_Store
Thumbs.db